{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/AGENTS.md", "README.md"],
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=ixwujmimgafnckqlezud",
      "enabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000,
    "tail_turns": 15
  },
  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },
  "skills": {
    "paths": [".opencode/skills", "/home/alexy/.config/opencode/skills"]
  },
  "reference": {
    "docs": {
      "path": ".",
      "description": "Use for project structure, architecture, and config details"
    }
  }
}
