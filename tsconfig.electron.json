{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "declaration": false
  },
  "include": ["electron/**/*", "src/**/*"],
  "exclude": ["node_modules", "out", "dist", "output", "src/renderer/**/*"]
}
