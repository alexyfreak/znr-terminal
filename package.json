{
  "name": "zunoora-desktop",
  "version": "1.0.0",
  "description": "Uzbekistan teacher document assistant — Electron desktop app for generating official school documents",
  "author": "Zunoora Team <info@zunoora.uz>",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:win": "electron-vite build && electron-builder --win --config",
    "package:dir": "electron-vite build && electron-builder --win --dir --config"
  },
  "build": {
    "appId": "uz.zunoora.app",
    "productName": "Zunoora",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!src/**/*",
      "!electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zunoora",
      "artifactName": "Zunoora-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
