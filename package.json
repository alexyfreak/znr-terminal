{
  "name": "zunoora-cli",
  "version": "1.0.0",
  "description": "Uzbekistan teacher document assistant — CLI tool for automating school document workflows",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build",
    "preview:electron": "electron-vite preview",
    "package:win": "electron-vite build && electron-builder --win --config",
    "package:dir": "electron-vite build && electron-builder --win --dir --config"
  },
  "build": {
    "appId": "uz.zunoora.app",
    "productName": "Zunoora",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!src/**/*",
      "!electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zunoora",
      "artifactName": "Zunoora-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "inquirer": "^10.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6"
  }
}
