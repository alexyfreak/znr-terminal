# =============================================================================
# Zunoora — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: .env is in .gitignore — never commit real secrets!
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Payme Merchant API ─────────────────────────────────────────────────────
# Get these from your Payme merchant cabinet
# Leave empty to fall back to direct checkout links (manual confirm only)

PAYME_ID=
PAYME_KEY=
PAYME_IS_TEST=true

# ── Click Merchant API ─────────────────────────────────────────────────────
# Get these from your Click merchant cabinet → Settings → API
# Leave empty to fall back to direct checkout links (manual confirm only)

CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_IS_TEST=true

# ── Bug Report Gmail SMTP ─────────────────────────────────────────────────
# Send bug reports via Gmail SMTP. You need a Gmail app password:
# 1. Enable 2FA at https://myaccount.google.com/security
# 2. Generate app password at https://myaccount.google.com/apppasswords
# 3. Use your full Gmail address as GMAIL_USER and the 16-char app password below

GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Development ────────────────────────────────────────────────────────────
# Set by electron-vite automatically in dev mode

VITE_DEV_SERVER_URL=http://localhost:5173
